{
    "name": "asyncalchemist/breezedoc-sdk",
    "description": "PHP SDK for the Breezedoc e-signature API",
    "type": "library",
    "license": "MIT",
    "keywords": ["breezedoc", "e-signature", "api", "sdk", "documents", "signing"],
    "authors": [
        {
            "name": "AsyncAlchemist",
            "email": "17990601+AsyncAlchemist@users.noreply.github.com"
        }
    ],
    "homepage": "https://github.com/AsyncAlchemist/breezedoc-sdk",
    "require": {
        "php": "^7.4 || ^8.0",
        "psr/http-client": "^1.0",
        "psr/http-message": "^1.0 || ^2.0",
        "psr/http-factory": "^1.0",
        "php-http/discovery": "^1.17"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.5",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.7",
        "guzzlehttp/guzzle": "^7.0",
        "php-http/mock-client": "^1.6",
        "nyholm/psr7": "^1.8",
        "vlucas/phpdotenv": "^5.5"
    },
    "autoload": {
        "psr-4": {
            "Breezedoc\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Breezedoc\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite=Unit",
        "test:integration": "phpunit --testsuite=Integration",
        "cs": "phpcs --standard=PSR12 src/",
        "cs:fix": "phpcbf --standard=PSR12 src/",
        "analyse": "phpstan analyse src/ --level=8"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
